# Environment Variables — AdRemix
# Copy to .env.local and fill in values

# Fal.ai — Server-side only (no VITE_ prefix)
FAL_KEY=fal-xxxxxxxxxxxxxxxx

# API proxy URL for Fal.ai calls
VITE_FAL_PROXY_URL=/api/fal

# General API base
VITE_API_BASE_URL=/api

# Supabase (Phase 2)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Pinokio local model (optional)
# PINOKIO_BASE_URL=http://localhost:7860
